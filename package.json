{
  "name": "citio",
  "version": "0.1.4",
  "description": "Self-hosted AI coding agents that live in Slack — run Claude Code or Codex in your own infra, ship PRs, and keep every credential behind a controlled MCP tool layer.",
  "keywords": [
    "slack",
    "ai-agent",
    "claude-code",
    "codex",
    "mcp",
    "devops",
    "self-hosted",
    "aws-ecs",
    "coding-agent"
  ],
  "homepage": "https://github.com/lawrencehui/Citio#readme",
  "bugs": {
    "url": "https://github.com/lawrencehui/Citio/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lawrencehui/Citio.git"
  },
  "license": "MIT",
  "author": "Lawrence Hui <hkc.lawrence@gmail.com>",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "citio": "./dist/cli/init.js"
  },
  "files": [
    "dist",
    "Dockerfile",
    ".dockerignore",
    "citio.example.yaml"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/cli/init.js",
    "init": "tsx src/cli/init.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1019.0",
    "@aws-sdk/client-ecr": "^3.1019.0",
    "@aws-sdk/client-ecs": "^3.1019.0",
    "@aws-sdk/client-efs": "^3.1019.0",
    "@aws-sdk/client-iam": "^3.1019.0",
    "@aws-sdk/client-sts": "^3.1019.0",
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@slack/bolt": "^4.6.0",
    "dotenv": "^17.3.1",
    "keytar": "^7.9.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
